local function app(cmd, args)
    require("config.nvim_dev").app(cmd, args)
end

local file_exists = require("yabs.conditions").file_exists

local function input_default(prompt, default)
    local value = vim.fn.input(prompt, default)

    if value == nil or value == "" then
        return default
    end

    return value
end


return {
    tasks = {
        ["run"] = {
            command = function()
                local build_dir = "build"
                app("wine", {
                    build_dir .. "/app"
                })
            end,
            condition = file_exists("build/app"),
            type = "lua",
        },
        ["cmake -B build -S ."] = {
            command = function()
                local build_dir = "build"

                app("cmake", {
                    "-S",
                    ".",
                    "-B",
                    build_dir
                })
            end,
            type = "lua",
            desc = "Configure",
        },

        ["cmake --build build"] = {
            command = function()
                local build_dir = "build"

                app("cmake", {
                    "--build",
                    build_dir,
                })
            end,
            type = "lua",
            desc = "Build",
        },
        ["rm -rf build"] = {
            command = function()
                local build_dir = "build"

                app("sh", {
                    "-c",
                    string.format(
                        "rm -rf %q",
                        build_dir
                    ),
                })
            end,
            type = "lua",
            desc = "Clean",
        },
        ["cmake --build build --clean-first"] = {
            command = function()
                local build_dir = "build"
                app("cmake", {
                    "--build",
                    build_dir,
                    "--clean-first",
                })
            end,
            type = "lua",
            desc = "Clean and Build",
        },


    },
}
